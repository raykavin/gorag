# Postgres (if you are going to use)
# POSTGRES_USER=my-application
# POSTGRES_PASSWORD=my-application
# POSTGRES_DB=my-application

# Timezone
TZ=America/Belem

# Project
PROJECT_NAME=my-application

# Git configuration
GIT_CONFIG_DEV_USERNAME=your_user_name
GIT_CONFIG_DEV_EMAIL=your-email@example.com
GIT_REPO_ADDRESS=https://github.com/raykavin/devcontainer-go.git
GIT_INIT_DEFAULT_BRANCH=develop